<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StateFlowTestActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="StateFlow 始终持有最新值，新订阅者会立即收到当前值，相同的值不会重复发射。"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="计数 StateFlow"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="count = 0"
            android:textColor="#1565C0"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnIncrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="increment（+1）"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSameValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发射相同的值（去重，不会通知）"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnAutoIncrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动 +1（每秒一次，共 5 次）"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="网络状态 StateFlow（必须有初始值）"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNetworkStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="未连接"
            android:textColor="#C62828"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnToggleNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="切换网络连接状态"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="多订阅者收集日志（也会输出到 Logcat，TAG=StateFlowTest）"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text=""
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>
